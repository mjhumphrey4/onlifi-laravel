<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=0.85">
    <title>Sign in to Bite Tech Network</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(180deg, #6e04c4 0%, #072ada 100%);
            min-height: 100vh;
            color: #ffffff;
            padding: 15px;
        }

        .container {
            max-width: 700px;
            margin: 0 auto;
            padding-top: 20px;
        }

        .header {
            text-align: center;
            margin-bottom: 25px;
        }

        .wifi-icon {
            font-size: 45px;
            margin-bottom: 8px;
        }

        .wifi-icon img,
        .wifi-icon svg {
            width: 150px;
            height: 150px;
            display: block;
            margin: 0 auto;
        }

        .company-name {
            font-size: 25px;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 20px;
            line-height: 1.3;
        }

        .voucher-section {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            padding: 18px 16px;
            margin-bottom: 18px;
            border: 1px solid rgba(74, 222, 128, 0.25);
        }

        .input-group {
            display: flex;
            gap: 8px;
            margin-bottom: 12px;
        }

        #voucherCode, #username, #password, #simplePassword, #phone-number, #verify-code {
            flex: 1;
            padding: 11px 14px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(74, 222, 128, 0.3);
            border-radius: 7px;
            color: #ffffff;
            font-size: 19px;
            outline: none;
            transition: all 0.3s;
        }

        #voucherCode::placeholder, #username::placeholder, #password::placeholder,
        #simplePassword::placeholder, #phone-number::placeholder, #verify-code::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

        #voucherCode:focus, #username:focus, #password:focus,
        #simplePassword:focus, #phone-number:focus, #verify-code:focus {
            border-color: #4ade80;
            background: rgba(255, 255, 255, 0.12);
        }

        .login-btn {
            width: 100%;
            padding: 11px;
            background: #cc0606;
            color: #ffffff;
            border: none;
            border-radius: 7px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .login-btn:hover {
            background: #224bc5;
        }

        .find-voucher {
            text-align: center;
            margin-top: 12px;
        }

        .find-voucher a {
            color: #4ade80;
            text-decoration: none;
            font-size: 12px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .divider {
            text-align: center;
            margin: 18px 0;
            color: rgba(255, 255, 255, 0.65);
            font-size: 13px;
        }

        .package-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(74, 222, 128, 0.25);
            border-radius: 10px;
            padding: 14px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.3s;
        }

        .package-card:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(74, 222, 128, 0.4);
        }

        .package-info {
            flex: 1;
        }

        .package-title {
            font-size: 16px;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 2px;
        }

        .package-duration {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.6);
        }

        .package-price {
            font-size: 18px;
            font-weight: 700;
            color: #4ade80;
            margin: 0 12px;
        }

        .buy-btn {
            padding: 9px 22px;
            background: #cc0606;
            color: #ffffff;
            border: none;
            border-radius: 7px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .buy-btn:hover {
            background: #22c55e;
        }

        .footer-text {
            text-align: center;
            margin-top: 20px;
            color: rgba(255, 255, 255, 0.5);
            font-size: 12px;
        }

        #oper-hint {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #fca5a5;
            padding: 9px;
            border-radius: 7px;
            margin-bottom: 12px;
            text-align: center;
            font-size: 12px;
            display: none;
        }

        #hotspot-section, #input-user, #input-password, #input-simple,
        #input-phone-num, #input-verify-code, #button-facebook {
            display: none;
        }

        #hotspot-selector {
            width: 100%;
            padding: 11px 14px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(74, 222, 128, 0.3);
            border-radius: 7px;
            color: #ffffff;
            font-size: 14px;
            margin-bottom: 12px;
            cursor: pointer;
        }

        #country-code {
            width: 70px;
            padding: 11px 10px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(74, 222, 128, 0.3);
            border-radius: 7px;
            color: #ffffff;
            font-size: 14px;
        }

        #get-code {
            padding: 11px 18px;
            background: #4ade80;
            color: #0a1f1a;
            border: none;
            border-radius: 7px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            white-space: nowrap;
        }

/* Add this CSS to your existing styles */

/* Modal Overlay */
.payment-modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.75);
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 20px;
}

.payment-modal-overlay.show {
    display: flex;
}

/* Modal Container */
.payment-modal {
    background: linear-gradient(180deg, #0a1f1a 0%, #1a3a2e 100%);
    border-radius: 12px;
    max-width: 450px;
    width: 100%;
    padding: 25px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(74, 222, 128, 0.3);
    position: relative;
}

/* Modal Header */
.modal-header {
    text-align: center;
    margin-bottom: 20px;
}

.modal-header h2 {
    color: #4ade80;
    font-size: 22px;
    margin-bottom: 8px;
}

.modal-header p {
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
}

/* Package Summary */
.package-summary {
    background: rgba(74, 222, 128, 0.1);
    border: 1px solid rgba(74, 222, 128, 0.3);
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 20px;
}

.package-summary-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: 14px;
}

.package-summary-row:last-child {
    margin-bottom: 0;
    padding-top: 8px;
    border-top: 1px solid rgba(74, 222, 128, 0.2);
    font-weight: 600;
}

.package-summary-label {
    color: rgba(255, 255, 255, 0.7);
}

.package-summary-value {
    color: #ffffff;
    font-weight: 600;
}

.package-summary-amount {
    color: #4ade80;
    font-size: 18px;
}

/* Form Group */
.modal-form-group {
    margin-bottom: 18px;
}

.modal-form-group label {
    display: block;
    color: rgba(255, 255, 255, 0.85);
    font-size: 13px;
    margin-bottom: 8px;
    font-weight: 500;
}

.modal-form-group input {
    width: 100%;
    padding: 12px 14px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(74, 222, 128, 0.3);
    border-radius: 7px;
    color: #ffffff;
    font-size: 14px;
    outline: none;
    transition: all 0.3s;
}

.modal-form-group input::placeholder {
    color: rgba(255, 255, 255, 0.5);
}

.modal-form-group input:focus {
    border-color: #4ade80;
    background: rgba(255, 255, 255, 0.12);
}

.modal-form-group small {
    display: block;
    color: rgba(255, 255, 255, 0.6);
    font-size: 12px;
    margin-top: 5px;
}

/* Payment Status */
.payment-status {
    display: none;
    padding: 12px;
    border-radius: 7px;
    margin-bottom: 15px;
    text-align: center;
    font-size: 13px;
}

.payment-status.info {
    background: rgba(59, 130, 246, 0.15);
    border: 1px solid rgba(59, 130, 246, 0.3);
    color: #93c5fd;
}

.payment-status.success {
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #86efac;
}

.payment-status.error {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #fca5a5;
}

.payment-status code {
    background: rgba(0, 0, 0, 0.3);
    padding: 2px 8px;
    border-radius: 4px;
    font-family: monospace;
    font-size: 15px;
    color: #4ade80;
}

.status-spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #4ade80;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin-left: 8px;
    vertical-align: middle;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Modal Actions */
.modal-actions {
    display: flex;
    gap: 10px;
    margin-top: 20px;
}

.modal-btn {
    flex: 1;
    padding: 12px;
    border: none;
    border-radius: 7px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
}

.modal-btn-primary {
    background: #4ade80;
    color: #0a1f1a;
}

.modal-btn-primary:hover:not(:disabled) {
    background: #22c55e;
}

.modal-btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.modal-btn-secondary {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    border: 1px solid rgba(74, 222, 128, 0.3);
}

.modal-btn-secondary:hover:not(:disabled) {
    background: rgba(255, 255, 255, 0.12);
}

.modal-btn-secondary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

    </style>
</head>
