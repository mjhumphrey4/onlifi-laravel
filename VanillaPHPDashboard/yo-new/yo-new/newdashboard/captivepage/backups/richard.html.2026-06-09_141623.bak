//New Show Success Logic to Input Voucher withotu redirection

// Show voucher success and auto-fill voucher code, then close modal

function showVoucherSuccess(voucherCode) {
    document.getElementById('paymentStatus').className = 'payment-status success';
    document.getElementById('statusText').innerHTML = `<strong>✅ Payment Successful!</strong><br>Your Voucher Code is: <code>${voucherCode}</code>`;
    document.getElementById('statusSpinner').style.display = 'none';
    document.getElementById('paymentStatus').style.display = 'block';

    // Disable the 'Proceed to Pay' button, but keep 'Cancel' to allow closing if needed
    document.getElementById('proceedBtn').disabled = true;
    // Note: Keeping cancelBtn enabled might be confusing after success. You could disable it too.
    // document.getElementById('cancelBtn').disabled = true;

    // Update the success message to inform the user the modal will close
    let countdown = 3;
    const countdownInterval = setInterval(() => {
        if (countdown > 0) {
            document.getElementById('statusText').innerHTML = `<strong>✅ Payment Successful!</strong><br>Your Voucher Code is: <code>${voucherCode}</code><br>Closing modal... (${countdown}s)`;
            countdown--;
        } else {
            clearInterval(countdownInterval);
        }
    }, 1000);

    // Set a timeout to fill the voucher code into the input field and close the modal
    setTimeout(function() {
        // Hide the payment modal
        document.getElementById('paymentModal').classList.remove('show');

        // Find the voucher code input field on the main page
        const voucherInput = document.getElementById('voucherCode');
        if (voucherInput) {
            // Fill the voucher code field
            voucherInput.value = voucherCode;
            // Optionally, focus the input field to make it clear it's ready
            voucherInput.focus();
            console.log("Voucher code filled into input field:", voucherCode);
            // Optionally, select the text so the user can easily see/modify it if needed
            // voucherInput.select();
        } else {
            console.error("Voucher code input field (#voucherCode) not found on the main page.");
        }

        // The modal is closed, and the voucher code is in the input field.
        // The user must now click the main login button to submit the form.
        // The existing handleSubmit logic will take care of the rest.

    }, 2000); // 3 seconds delay before filling the input and closing modal
}

// Show payment error
function showPaymentError(message) {
    document.getElementById('paymentStatus').className = 'payment-status error';
    document.getElementById('statusText').innerHTML = `<strong>❌ ${message}</strong>`;
    document.getElementById('statusSpinner').style.display = 'none';
    document.getElementById('proceedBtn').disabled = false;
    document.getElementById('cancelBtn').disabled = false;
}

// Event listeners for modal
document.getElementById('proceedBtn').addEventListener('click', proceedPayment);
document.getElementById('cancelBtn').addEventListener('click', closePaymentModal);

// Allow Enter key to submit
document.getElementById('phoneInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') proceedPayment();
});

document.getElementById('emailInput').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') proceedPayment();
});

// Close modal when clicking outside
document.getElementById('paymentModal').addEventListener('click', function(e) {
    if (e.target === this) {
        closePaymentModal();
    }
});
</script>
</body>
</html>