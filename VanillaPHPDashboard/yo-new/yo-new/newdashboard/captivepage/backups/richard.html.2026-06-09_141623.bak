            <h1>GANDA CONNECT WIFI</h1>
        </div>

        <div id="oper-hint"></div>

        <div id="hotspot-section">
            <select id="hotspot-selector"></select>
        </div>

        <div class="voucher-section">
            <form id="login-form">
                <div id="input-voucher">
                    <div class="input-group">
                        <input id="voucherCode" name="voucherCode" type="text" placeholder="Enter your voucher here"/>
                    </div>
                </div>

                <div id="input-user">
                    <div class="input-group">
                        <input id="username" name="username" type="text" placeholder="Username"/>
                    </div>
                </div>

                <div id="input-password">
                    <div class="input-group">
                        <input id="password" name="password" type="password" placeholder="Password"/>
                    </div>
                </div>

                <div id="input-simple">
                    <div class="input-group">
                        <input id="simplePassword" name="simplePassword" type="password" placeholder="Password"/>
                    </div>
                </div>

                <div id="input-phone-num">
                    <div class="input-group">
                        <input id="country-code" type="text" value="">
                        <input id="phone-number" name="phone-number" type="text" placeholder="Phone Number"/>
                    </div>
                </div>

                <div id="input-verify-code">
                    <div class="input-group">
                        <input id="verify-code" name="verify-code" type="text" placeholder="Verification Code"/>
                        <button id="get-code" type="button">Get Code</button>
                    </div>
                </div>
            </form>

            <div id="button-area">
                <button id="button-facebook">Facebook</button>
                <button id="button-login" type="submit" class="login-btn">Connect</button>
            </div>

            <div class="find-voucher">
                <a href="#find">🔍 Already bought? Find My Voucher</a>
            </div>
        </div>

        <div class="divider">Select a package and pay with Mobile Money</div>

        <div id="packages">
            <div class="package-card">
                <div class="package-info">
                    <div class="package-title">2 Hours</div>
                    <div class="package-duration">2 Hours</div>
                </div>
                <div class="package-price">UGX 500</div>
                <button class="buy-btn" onclick="selectPackage('2hours', 492)">BUY</button>
            </div>

            <div class="package-card">
                <div class="package-info">
                    <div class="package-title">4 Hours</div>
                    <div class="package-duration">4 Hours</div>
                </div>
                <div class="package-price">UGX 800</div>
                <button class="buy-btn" onclick="selectPackage('4hours', 788)">BUY</button>
            </div>

            <div class="package-card">
                <div class="package-info">
                    <div class="package-title">12 Hours</div>
                    <div class="package-duration">12 Hours</div>
                </div>
                <div class="package-price">UGX 1,000</div>
                <button class="buy-btn" onclick="selectPackage('12hours', 985)">BUY</button>
            </div>

            <div class="package-card">
                <div class="package-info">
                    <div class="package-title">24 Hours</div>
                    <div class="package-duration">24 Hours</div>
                </div>
                <div class="package-price">UGX 2,000</div>
                <button class="buy-btn" onclick="selectPackage('24hours', 1970)">BUY</button>
            </div>

            <div class="package-card">
                <div class="package-info">
                    <div class="package-title">Weekly</div>
                    <div class="package-duration">7 Days</div>
                </div>
                <div class="package-price">UGX 6,000</div>
                <button class="buy-btn" onclick="selectPackage('7days', 5910)">BUY</button>
            </div>

            <div class="package-card">
                <div class="package-info">
                    <div class="package-title">Monthly</div>
                    <div class="package-duration">30 Days</div>
                </div>
                <div class="package-price">UGX 25,000</div>
                <button class="buy-btn" onclick="selectPackage('30days', 25000)">BUY</button>
            </div>
        </div>
<!-- Add this HTML right before the closing </body> tag -->

<div id="paymentModal" class="payment-modal-overlay">
    <div class="payment-modal">
        <div class="modal-header">
            <h2>Complete Your Purchase</h2>
            <p>Enter your details to proceed with payment</p>
        </div>

        <div id="packageSummary" class="package-summary">
            <div class="package-summary-row">
                <span class="package-summary-label">Package:</span>
                <span class="package-summary-value" id="summaryPackage">-</span>
            </div>
            <div class="package-summary-row">
                <span class="package-summary-label">Duration:</span>
                <span class="package-summary-value" id="summaryDuration">-</span>
            </div>
            <div class="package-summary-row">
                <span class="package-summary-label">Amount:</span>
                <span class="package-summary-amount" id="summaryAmount">-</span>
            </div>
        </div>

        <div id="paymentStatus" class="payment-status">
            <span id="statusText"></span>
            <span id="statusSpinner" class="status-spinner" style="display: none;"></span>
        </div>

        <div class="modal-form-group">
            <label for="phoneInput">Phone Number *</label>
            <input type="tel" id="phoneInput" placeholder="0712345678 or 256712345678" autocomplete="tel">
            <small>Enter your MTN or Airtel number</small>
        </div>

        <div class="modal-form-group">
            <label for="emailInput">Email (Optional)</label>
            <input type="email" id="emailInput" placeholder="your@email.com" autocomplete="email">
            <small>For payment receipts and voucher backup</small>
        </div>

        <div class="modal-actions">
            <button id="cancelBtn" class="modal-btn modal-btn-secondary">Cancel</button>
            <button id="proceedBtn" class="modal-btn modal-btn-primary">Proceed to Pay</button>
        </div>
    </div>
</div>
        <div class="footer-text">
            We accept: MTN Mobile Money & Airtel Money
        </div>
    </div>

    <script>
        // [ALL THE SAME JAVASCRIPT CODE FROM THE PREVIOUS VERSION - KEEPING IT EXACTLY THE SAME]
        var Ajax = {
            post: function (url, data, fn) {
                var xhr = new XMLHttpRequest();
                xhr.open("POST", url, true);
                xhr.setRequestHeader("Content-Type", "application/json");
                xhr.onreadystatechange = function() {
                    if (xhr.readyState == 4 && (xhr.status == 200 || xhr.status == 304)) {
                        fn.call(this, xhr.responseText);
                    }
                };
                xhr.send(data);
            }
        };

        function getQueryStringKey(key) { return getQueryStringAsObject()[key]; }
        
        function getQueryStringAsObject() {
            var b, cv, e, k, ma, sk, v, r = {},
                d = function (v) { return decodeURIComponent(v); },
                q = window.location.search.substring(1),
                s = /([^&;=]+)=?([^&;]*)/g;
            ma = function(v) {
                if (typeof v != "object") {
                    cv = v; v = {}; v.length = 0;
                    if (cv) { Array.prototype.push.call(v, cv); }
                }
                return v;
            };
            while (e = s.exec(q)) {
                b = e[1].indexOf("[");
                v = d(e[2]);
                if (b < 0) {
                    k = d(e[1]);
                    if (r[k]) {
                        r[k] = ma(r[k]);
                        Array.prototype.push.call(r[k], v);
                    } else {
                        r[k] = v;
                    }
                } else {
                    k = d(e[1].slice(0, b));
                    sk = d(e[1].slice(b + 1, e[1].indexOf("]", b)));
                    r[k] = ma(r[k]);
                    if (sk) { r[k][sk] = v; }
                    else { Array.prototype.push.call(r[k], v); }
                }
            }
            return r;
        }

        var data = {}, globalConfig = {}, submitUrl;
        var clientMac = getQueryStringKey("clientMac");
        var apMac = getQueryStringKey("apMac");
        var gatewayMac = getQueryStringKey("gatewayMac") || undefined;
        var ssidName = getQueryStringKey("ssidName") || undefined;
        var radioId = !!getQueryStringKey("radioId")? Number(getQueryStringKey("radioId")) : undefined;
        var vid = !!getQueryStringKey("vid")? Number(getQueryStringKey("vid")) : undefined;
        var originUrl = getQueryStringKey("originUrl");
        
        var hotspotMap = {3: "Voucher Access", 5: "Local User Access", 6: "SMS Access", 8: "RADIUS Access"};
        var errorHintMap = {"0": "Successfully Unlocked!", "-1": "General error.", "-41502": "Wrong voucher code", "-41503": "Voucher expired", "-41517": "Incorrect password."};
        var facebookUrl = !!apMac? ('/portal/fbwifi/forward?clientMac='+encodeURIComponent(clientMac)+'&apMac='+encodeURIComponent(apMac)+'&ssidName='+encodeURIComponent(ssidName)+'&radioId='+encodeURIComponent(radioId)+'&originUrl='+encodeURIComponent(originUrl)) : ('/portal/fbwifi/forward?clientMac='+encodeURIComponent(clientMac)+'&gatewayMac='+encodeURIComponent(gatewayMac)+'&vid='+encodeURIComponent(vid)+'&originUrl='+encodeURIComponent(originUrl));
        var isCommited;

        Ajax.post('/portal/getPortalPageSetting', JSON.stringify({clientMac,apMac,gatewayMac,ssidName,radioId,vid,originUrl}), function (res) {
            res = JSON.parse(res);
            data = res.result;
            submitUrl = "/portal/auth";
            var landingUrl = data.landingUrl;
            isCommited = false;
            globalConfig = {authType: data.authType, hotspotTypes: !!data.hotspot && data.hotspot.enabledTypes || [], error: data.error || 'ok', countryCode: !!data.sms && data.sms.countryCode || 1};
            
            function pageConfigParse(){
                if (res.errorCode !== 0){ document.getElementById("oper-hint").style.display = "block"; document.getElementById("oper-hint").innerHTML = errorHintMap[res.errorCode]; }
                document.getElementById("hotspot-section").style.display = "none";
                document.getElementById("input-voucher").style.display = "none";
                document.getElementById("input-user").style.display = "none";
                document.getElementById("input-password").style.display = "none";
                document.getElementById("input-simple").style.display = "none";
                document.getElementById("input-phone-num").style.display = "none";
                document.getElementById("input-verify-code").style.display = "none";
                document.getElementById("button-facebook").style.display = "none";
                switch (globalConfig.authType){
                    case 0: window.authType = 0; break;
                    case 1: document.getElementById("input-simple").style.display = "block"; window.authType = 1; break;
                    case 2: hotspotChang(2); window.authType = 2; break;
                    case 7: document.getElementById("button-facebook").style.display = "block"; document.getElementById("button-facebook").addEventListener("click", function () { window.location.href = facebookUrl; }); document.getElementById("button-login").style.display = "none"; window.authType = 7; break;
                    case 11: var options = ""; for (var i=0;i<globalConfig.hotspotTypes.length;i++) { options += '<option value="'+globalConfig.hotspotTypes[i]+'">'+hotspotMap[globalConfig.hotspotTypes[i]]+'</option>'; } if (globalConfig.hotspotTypes.length > 1) { document.getElementById("hotspot-section").style.display = "block"; } document.getElementById("hotspot-selector").innerHTML = options; hotspotChang(globalConfig.hotspotTypes[0]); window.authType = globalConfig.hotspotTypes[0]; break;
                }
            }
            
            function handleSubmit(){
                var submitData = {}; submitData['authType'] = window.authType;
                switch (window.authType){
                    case 3: submitData['voucherCode'] = document.getElementById("voucherCode").value; break;
                    case 5: submitData['localuser'] = document.getElementById("username").value; submitData['localuserPsw'] = document.getElementById("password").value; break;
                    case 1: submitData['simplePassword'] = document.getElementById("simplePassword").value; break;
                    case 6: submitData['phone'] = document.getElementById("country-code").value + document.getElementById("phone-number").value; submitData['code'] = document.getElementById("verify-code").value; break;
                    case 2: case 8: submitData['username'] = document.getElementById("username").value; submitData['password'] = document.getElementById("password").value; break;
                }
                if(isCommited == false){
                    submitData['clientMac'] = clientMac; submitData['apMac'] = apMac; submitData['gatewayMac'] = gatewayMac; submitData['ssidName'] = ssidName; submitData['radioId'] = radioId; submitData['vid'] = vid;
                    if(window.authType == 2 || window.authType == 8){ submitUrl = "/portal/radius/auth"; submitData['authType'] = window.authType; } else { submitData['originUrl'] = originUrl; }
                    Ajax.post(submitUrl, JSON.stringify(submitData).toString(), function(data){ data = JSON.parse(data); if(!!data && data.errorCode === 0) { isCommited = true; window.location.href = landingUrl; } else{ document.getElementById("oper-hint").style.display = "block"; document.getElementById("oper-hint").innerHTML = errorHintMap[data.errorCode]; } });
                }
            }
            
            function hotspotChang (type) {
                document.getElementById("input-voucher").style.display = "none"; document.getElementById("input-user").style.display = "none"; document.getElementById("input-password").style.display = "none"; document.getElementById("input-phone-num").style.display = "none"; document.getElementById("input-verify-code").style.display = "none"; document.getElementById("button-login").style.display = "block"; window.authType = type;
                switch (Number(type)) {
                    case 3: document.getElementById("input-voucher").style.display = "block"; break;
                    case 5: case 2: case 8: document.getElementById("input-user").style.display = "block"; document.getElementById("input-password").style.display = "block"; break;
                    case 6: document.getElementById("input-phone-num").style.display = "block"; document.getElementById("input-verify-code").style.display = "block"; break;
                }
            }
            
            document.getElementById("country-code").value = parseInt(globalConfig.countryCode, 10);
            document.getElementById("hotspot-selector").addEventListener("change", function () { var obj = document.getElementById("hotspot-selector"); var opt = obj.options[obj.selectedIndex]; hotspotChang(opt.value); });
            document.getElementById("button-login").addEventListener("click", handleSubmit);
            document.getElementById("get-code").addEventListener("click", function(e){ e.preventDefault(); var phoneNum = document.getElementById("phone-number").value; Ajax.post("/portal/sendSmsAuthCode", JSON.stringify({clientMac,apMac,gatewayMac,ssidName,radioId,vid,phone: "+" + document.getElementById("country-code").value + phoneNum}),function(data){ data = JSON.parse(data); document.getElementById("oper-hint").style.display = "block"; document.getElementById("oper-hint").innerHTML = data.errorCode !== 0 ? errorHintMap[data.errorCode] : "SMS sent successfully."; }); });
            pageConfigParse();
        });
    </script>
<script>

// Add these variables at the top of your script section (after the existing variables)
let pendingPayment = null;
let pollInterval = null;
let pollCount = 0;
const MAX_POLLS = 40; // 5 minutes max (60 * 5 seconds)
const CURRENT_ORIGIN_SITE = 'Richard Network'; // Change this to your actual site name

// Replace the existing selectPackage function with this one
function selectPackage(voucherType, amount) {
    // Store package selection details
    const packageNames = {
        '2hours': '2 Hours',
        '4hours': '4 Hours',
        '12hours': '12 Hours',
        '24hours': '24 Hours',
        '7days': 'Weekly',
        '30days': 'Monthly'
    };

    const packageDurations = {
        '2hours': '2 Hours',
        '4hours': '4 Hours',
        '12hours': '12 Hours',
        '24hours': '24 Hours',
        '7days': '7 Days',
        '30days': '30 Days'
    };

    // Ensure all Omada variables are captured with fallbacks
    pendingPayment = {
        packageType: voucherType,
        amount: amount,
        packageName: packageNames[voucherType],
        packageDuration: packageDurations[voucherType],
        clientMac: clientMac || '',
        apMac: apMac || '',
        gatewayMac: gatewayMac || '',
        ssidName: ssidName || '',
        radioId: radioId || '',
        vid: vid || '',
        originUrl: originUrl || window.location.href,
        landingUrl: (typeof data !== 'undefined' && data.landingUrl) ? data.landingUrl : (originUrl || window.location.href),
        previewSite: CURRENT_ORIGIN_SITE
    };
    
    console.log("Package selected - pendingPayment:", pendingPayment);

    // Update modal summary
    document.getElementById('summaryPackage').textContent = packageNames[voucherType];
    document.getElementById('summaryDuration').textContent = packageDurations[voucherType];
    document.getElementById('summaryAmount').textContent = 'UGX ' + amount.toLocaleString();

    // Reset form and status
    document.getElementById('phoneInput').value = '';
    document.getElementById('emailInput').value = '';
    document.getElementById('paymentStatus').style.display = 'none';
    document.getElementById('proceedBtn').disabled = false;
    document.getElementById('cancelBtn').disabled = false;

    // Show modal
    document.getElementById('paymentModal').classList.add('show');
    document.getElementById('phoneInput').focus();
    
    // Debug: Log Omada variables
    console.log("Omada Variables Check:", {
        clientMac: clientMac,
        apMac: apMac,
        gatewayMac: gatewayMac,
        ssidName: ssidName,
        radioId: radioId,
        vid: vid,
        originUrl: originUrl
    });
}

// Function to normalize phone number to 256 format
function normalizePhoneNumber(phone) {
    // Remove all non-digit characters
    phone = phone.replace(/\D/g, '');
    
    // Handle different formats
    if (phone.startsWith('256')) {
        // Already in correct format
        return phone;
    } else if (phone.startsWith('0')) {
        // Remove leading 0 and add 256
        return '256' + phone.substring(1);
    } else if (phone.startsWith('7') && phone.length === 9) {
        // Missing 0, add 256
        return '256' + phone;
    } else if (phone.length === 9) {
        // Assume it's missing country code
        return '256' + phone;
    } else if (phone.startsWith('+256')) {
        // Remove + sign
        return phone.substring(1);
    }
    
    // Return as is if we can't determine format (will be validated by backend)
    return phone;
}

// Close modal function
function closePaymentModal() {
    document.getElementById('paymentModal').classList.remove('show');
    pendingPayment = null;
    if (pollInterval) {
        clearInterval(pollInterval);
        pollInterval = null;
    }
}

// Proceed with payment
function proceedPayment() {
    const phone = document.getElementById('phoneInput').value.trim();
    const email = document.getElementById('emailInput').value.trim();

    // Validate phone number
    if (!phone) {
        alert('Please enter your phone number');
        document.getElementById('phoneInput').focus();
        return;
    }

    // Normalize phone to 256 format
    const normalizedPhone = normalizePhoneNumber(phone);

    // Basic validation for 256 format (should be 12 digits: 256 + 9 digits)
    if (!normalizedPhone.startsWith('256') || normalizedPhone.length !== 12) {
        alert('Please enter a valid Ugandan phone number (e.g., 0712345678)');
        document.getElementById('phoneInput').focus();
        return;
    }

    // Validate email if provided
    if (email && !email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
        alert('Please enter a valid email address or leave it empty');
        document.getElementById('emailInput').focus();
        return;
    }

    // Start payment process
    initiatePayment(normalizedPhone, email);
}

// Initiate payment function
function initiatePayment(phone, email) {
    // Prepare UI for processing
    document.getElementById('proceedBtn').disabled = true;
    document.getElementById('cancelBtn').disabled = true;
    document.getElementById('paymentStatus').className = 'payment-status info';
    document.getElementById('statusText').innerHTML = '<strong>Initiating payment...</strong>';
    document.getElementById('statusSpinner').style.display = 'inline-block';
    document.getElementById('paymentStatus').style.display = 'block';

    // Clear any previous polling intervals
    if (pollInterval) {
        clearInterval(pollInterval);
    }
    pollCount = 0;

    // Prepare payment data - ensure all fields match PHP requirements
    const paymentData = {
        amount: parseFloat(pendingPayment.amount),
        msisdn: phone,
        origin_site: CURRENT_ORIGIN_SITE,
        client_mac: pendingPayment.clientMac || '',
        email: email || '',
        voucher_type: pendingPayment.packageType,
        origin_url: pendingPayment.originUrl || '',
        ap_mac: pendingPayment.apMac || '',
        gateway_mac: pendingPayment.gatewayMac || '',
        ssid_name: pendingPayment.ssidName || '',
        radio_id: pendingPayment.radioId || '',
        vid: pendingPayment.vid || '',
        landing_url: pendingPayment.landingUrl || '',
        preview_site: pendingPayment.previewSite || CURRENT_ORIGIN_SITE
    };

    console.log("Sending payment data to initiate.php:", paymentData);
    console.log("Pending payment object:", pendingPayment);

    // Call backend initiate endpoint
    fetch('https://bitetechsystems.com/omada-richard/initiate.php', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(paymentData)
    })
    .then(response => response.json())
    .then(initData => {
        console.log('Initiate response:', initData);

        if (initData.status === -1) {
            showPaymentError(initData.errorMessage || 'Payment initiation failed');
        } else if (initData.status === 1) {
            document.getElementById('statusText').innerHTML = '<strong>📱 Check your phone to confirm payment.</strong><br>Waiting for confirmation...';
            const ref = initData.transactionReference;

            if (!ref) {
                console.error('No transactionReference returned from backend:', initData);
                showPaymentError('Payment initiation error: Missing reference.');
                return;
            }

            console.log('Starting polling for Yo! ref:', ref);
            startPolling(ref);
        } else {
            console.warn('Unexpected status from backend:', initData.status);
            showPaymentError('Payment initiation returned unexpected status. Please try again.');
        }
    })
    .catch(err => {
        console.error('Network error during initiation:', err);
        showPaymentError('Network error during initiation. Please check your connection and try again.');
    });
}

// Start polling for payment status
function startPolling(ref) {
    pollInterval = setInterval(() => {
        pollCount++;
        console.log(`Polling attempt ${pollCount}/${MAX_POLLS} for ref: ${ref}`);

        if (pollCount > MAX_POLLS) {
            clearInterval(pollInterval);
            showPaymentError('Payment Failed. Please contact support on: 0776750646 if you were charged.');
            return;
        }

        fetch(`https://bitetechsystems.com/omada-richard/check_status.php?ref=${encodeURIComponent(ref)}&t=${Date.now()}`)
            .then(response => response.json())
            .then(checkData => {
                console.log('Status check response:', checkData);

                if (checkData.transactionStatus === 1) {
                    if (checkData.voucherCode) {
                        clearInterval(pollInterval);
                        pollInterval = null;
                        showVoucherSuccess(checkData.voucherCode);
                    } else {
                        console.warn('Status check returned success but no voucher code.');
                        document.getElementById('statusText').innerHTML = `<strong>✅ Payment confirmed.</strong><br>Assigning voucher... (${pollCount * 5}s)`;
                    }
                } else if (checkData.transactionStatus < 0) {
                    clearInterval(pollInterval);
                    pollInterval = null;
                    showPaymentError(checkData.errorMessage || 'Payment failed');
                } else {
                    document.getElementById('statusText').innerHTML = `<strong>⏳ Waiting for payment confirmation...</strong><br>(${pollCount * 5}s)`;
                }
            })
            .catch(err => {
                console.error('Polling error:', err);
                document.getElementById('statusText').innerHTML = `<strong>⏳ Network issue during check...</strong><br>retrying (${pollCount * 5}s)`;
            });
    }, 5000);
}

// Show voucher success and auto-submit
/* function showVoucherSuccess(voucherCode) {
    document.getElementById('paymentStatus').className = 'payment-status success';
    document.getElementById('statusText').innerHTML = `<strong>✅ Payment Successful!</strong><br>Your Voucher Code is: <code>${voucherCode}</code>`;
    document.getElementById('statusSpinner').style.display = 'none';
    document.getElementById('paymentStatus').style.display = 'block';

    document.getElementById('proceedBtn').disabled = true;
    document.getElementById('cancelBtn').disabled = true;

