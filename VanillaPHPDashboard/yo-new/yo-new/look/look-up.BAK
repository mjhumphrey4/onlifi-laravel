                        if (window.parent !== window) {
                            window.parent.postMessage({
                                type: 'VOUCHER_FOUND',
                                voucherCode: '<?php echo htmlspecialchars($response['voucher_code']); ?>'
                            }, '*');
                        }
                    </script>                    
                    
                <?php elseif ($response['status'] === 'pending'): ?>
                    <div style="text-align: center;">
                        <span style="font-size: 40px;">⏳</span>
