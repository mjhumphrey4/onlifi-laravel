APP_NAME="OnLiFi Payment System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=payment_mikrotik
DB_USERNAME=yo
DB_PASSWORD=password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@onlifi.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Timezone Configuration
APP_TIMEZONE=Africa/Nairobi

# YO! Uganda API Configuration
YOAPI_USERNAME=100812171094
YOAPI_PASSWORD=BUid-ZAmO-b2M0-vF6n-CzBK-PBaL-8qJK-6SOf
YOAPI_MODE=production

# Site Configuration
SITE_URL=https://bitetechsystems.com/yo/
FRONTEND_URL=http://localhost:5173

# SMS Configuration (Comms SDK)
SMS_PROVIDER=comms
SMS_API_KEY=
SMS_SENDER_ID=OnLiFi

# MikroTik Default Configuration
MIKROTIK_DEFAULT_HOST=192.168.88.1
MIKROTIK_DEFAULT_PORT=8728
MIKROTIK_DEFAULT_USERNAME=admin
MIKROTIK_DEFAULT_PASSWORD=admin

# Central Auth Database (Multi-tenant)
# This database stores tenant information, API keys, and user accounts
CENTRAL_DB_CONNECTION=mysql
CENTRAL_DB_HOST=127.0.0.1
CENTRAL_DB_PORT=3306
CENTRAL_DB_DATABASE=onlifi_central
CENTRAL_DB_USERNAME=onlifi_central
CENTRAL_DB_PASSWORD=password

# Note: The main DB_DATABASE setting above is used as a template
# for creating tenant databases. Each tenant gets their own database
# with a name like: onlifi_tenant_slug_randomid

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Session Configuration
SESSION_DOMAIN=localhost
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000
